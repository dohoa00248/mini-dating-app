<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Discover</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/css/reset.css" />
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/users.css">
</head>

<body class="bg-light">

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand fw-bold" href="#">DatingApp</a>

      <div class="ms-auto d-flex align-items-center gap-3">
        <span class="text-white small">
          Welcome, <%= newUser.name %>
        </span>
        <button 
          class="btn btn-outline-light btn-sm"
          onclick="loadLikes()">
          ❤️ View My Likes
        </button>
        <button 
          class="btn btn-warning btn-sm"
          onclick="loadMatches()">
          💘 View My Matches
        </button>
        <button 
  class="btn btn-info btn-sm"
  onclick="loadSchedules()">
  📅 View My Schedules
</button>
      </div>
    </div>
  </nav>

  <!-- HEADER -->
  <section class="py-5 text-center bg-white border-bottom">
    <div class="container">
      <h2 class="fw-bold">Discover People</h2>
      <p class="text-muted">Find your perfect match today.</p>
    </div>
  </section>

  <!-- FILTER -->
  <section class="py-4 bg-white">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <select class="form-select">
            <option selected>Filter by Gender</option>
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- USERS GRID -->
  <section class="py-5">
    <div class="container">
      <div class="row g-4">

      <% users.forEach(function(user) { %>

        <% 
          const isMatch = newUser.matches &&
            newUser.matches.some(id => id.toString() === user._id.toString());

          const isLiked = newUser.likes &&
            newUser.likes.some(id => id.toString() === user._id.toString());
        %>

        <div class="col-12 col-sm-6 col-lg-4">
          <div class="card user-card shadow-sm h-100" data-user-id="<%= user._id %>">

            <% if (isMatch) { %>
              <div class="match-label">💘 It’s a Match!</div>
            <% } %>

            <div class="card-body text-center d-flex flex-column">

              <!-- Avatar -->
              <div class="avatar mb-3">
                <% if (user.gender === 'Male') { %> 👨
                <% } else if (user.gender === 'Female') { %> 👩
                <% } else { %> 👤 <% } %>
              </div>

              <!-- Name + Age -->
              <h5 class="fw-bold">
                <%= user.name %>, <%= user.age %>
              </h5>

              <!-- Gender -->
              <p class="text-muted small mb-2">
                <%= user.gender %>
              </p>

              <!-- Bio -->
              <p class="text-muted small flex-grow-1">
                <%= user.bio || "No bio available yet." %>
              </p>

              <!-- Like Button -->
              <button 
                class="btn <%= isLiked ? 'btn-danger' : 'btn-outline-danger' %> w-100 like-btn"
                onclick="toggleLike('<%= user._id %>', this)">
                <%= isLiked ? '❤️ Liked' : '💖 Like' %>
              </button>

              <!-- Schedule Button -->
              <% if (isMatch) { %>
                <button 
                  class="btn btn-success btn-sm schedule-btn mt-2 w-100"
                  onclick="window.location.href='/users/<%= user._id %>/availability'">
                  📅 Suggest a Date
                </button>
              <% } %>

            </div>
          </div>
        </div>

      <% }) %>

      </div>
    </div>
  </section>

  <!-- MATCH POPUP -->
  <div id="matchPopup" class="match-popup">
    💘 It's a Match! You both liked each other.
  </div>

  <!-- LIKES MODAL -->
  <div class="modal fade" id="likesModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title">❤️ People You’ve Liked</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">

          <div id="likesLoading" class="text-center d-none">
            Loading...
          </div>

          <div id="likesEmpty" class="text-center text-muted d-none">
            You haven’t liked anyone yet.
          </div>

          <div id="likesList" class="row g-3"></div>

        </div>

      </div>
    </div>
  </div>

  <!-- MATCHES MODAL -->
  <div class="modal fade" id="matchesModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">

        <div class="modal-header">
          <h5 class="modal-title">💘 Your Matches</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">

          <div id="matchesLoading" class="text-center d-none">
            Loading...
          </div>

          <div id="matchesEmpty" class="text-center text-muted d-none">
            You don’t have any matches yet.
          </div>

          <div id="matchesList" class="row g-3"></div>

        </div>

      </div>
    </div>
  </div>
<!-- SCHEDULE MODAL -->
<div class="modal fade" id="scheduleModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content p-4">
      <h5 class="mb-3">📅 My Confirmed Schedules</h5>

      <div id="scheduleLoading" class="text-center d-none">
        Loading...
      </div>

      <div id="scheduleEmpty" class="text-center text-muted d-none">
        No confirmed schedules yet.
      </div>

      <div class="row g-3" id="scheduleList"></div>
    </div>
  </div>
</div>
<script src="/js/bootstrap.bundle.min.js"></script>
<script src="/js/users.js"></script>
</body>
</html>